{
	"name": "@chr33s/shopflare",
	"version": "2.2.8",
	"private": true,
	"type": "module",
	"scripts": {
		"actionlint": "if command -v actionlint 2>&1 >/dev/null; then actionlint; fi",
		"build": "react-router build",
		"codegen": "graphql-codegen",
		"deploy": "react-router build && wrangler deploy",
		"deploy:shopify": "shopify app deploy --message=$(git rev-parse --abbrev-ref HEAD):$npm_package_version --version=$(git rev-parse HEAD)",
		"dev": "react-router dev --host",
		"dev:shopify": "shopify app dev",
		"eslint": "eslint --cache --cache-location=./node_modules/.cache/eslint .",
		"prettier": "prettier --cache .",
		"preview": "react-router build && wrangler dev",
		"start": "wrangler dev",
		"test": "vitest --run",
		"tunnel": "source .env && cloudflared tunnel --no-autoupdate --url ${SHOPIFY_APP_URL}:8080 run --token ${CLOUDFLARE_API_TOKEN}",
		"typecheck": "tsc",
		"typegen": "wrangler types && react-router typegen"
	},
	"dependencies": {
		"@shopify/graphql-client": "1.3.0",
		"i18next": "24.2.2",
		"i18next-fetch-backend": "6.0.0",
		"isbot": "5.1.23",
		"jose": "6.0.8",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"react-i18next": "15.4.1",
		"react-router": "7.2.0",
		"remix-i18next": "7.0.2",
		"valibot": "1.0.0-rc.3"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "0.1.7",
		"@cloudflare/vitest-pool-workers": "0.7.4",
		"@cloudflare/workers-types": "4.20250224.0",
		"@eslint/css": "0.4.0",
		"@eslint/js": "9.21.0",
		"@react-router/dev": "7.2.0",
		"@react-router/serve": "7.2.0",
		"@shopify/api-codegen-preset": "1.1.4",
		"@shopify/app-bridge-react": "4.1.6",
		"@shopify/app-bridge-types": "0.0.16",
		"@shopify/polaris": "13.9.3",
		"@shopify/polaris-icons": "9.3.0",
		"@types/react": "18.3.18",
		"@types/react-dom": "18.3.5",
		"@vitest/browser": "3.0.7",
		"eslint": "9.21.0",
		"eslint-config-prettier": "10.0.2",
		"eslint-import-resolver-typescript": "3.8.3",
		"eslint-plugin-i18next": "6.1.1",
		"eslint-plugin-import-x": "4.6.1",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-react": "7.37.4",
		"eslint-plugin-react-hooks": "5.2.0",
		"eslint-plugin-regexp": "2.7.0",
		"globals": "16.0.0",
		"happy-dom": "17.1.8",
		"playwright": "1.50.1",
		"prettier": "3.5.2",
		"prettier-plugin-packagejson": "2.5.9",
		"react-router-dom": "7.2.0",
		"typescript": "5.7.3",
		"typescript-eslint": "8.25.0",
		"vite": "6.2.0",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "3.0.7",
		"vitest-browser-react": "0.1.1",
		"wrangler": "3.111.0"
	},
	"optionalDependencies": {
		"@shopify/cli": "3.76.0",
		"socket": "0.14.51"
	},
	"engines": {
		"node": "^22.14.0",
		"npm": ">=9.6.4"
	},
	"overrides": {
		"aggregate-error": "npm:@socketregistry/aggregate-error@^1",
		"array-buffer-byte-length": "npm:@socketregistry/array-buffer-byte-length@^1",
		"array-flatten": "npm:@socketregistry/array-flatten@^1",
		"array-includes": "npm:@socketregistry/array-includes@^1",
		"array.prototype.findlast": "npm:@socketregistry/array.prototype.findlast@^1",
		"array.prototype.flat": "npm:@socketregistry/array.prototype.flat@^1",
		"array.prototype.flatmap": "npm:@socketregistry/array.prototype.flatmap@^1",
		"array.prototype.tosorted": "npm:@socketregistry/array.prototype.tosorted@^1",
		"arraybuffer.prototype.slice": "npm:@socketregistry/arraybuffer.prototype.slice@^1",
		"available-typed-arrays": "npm:@socketregistry/available-typed-arrays@^1",
		"define-properties": "npm:@socketregistry/define-properties@^1",
		"es-define-property": "npm:@socketregistry/es-define-property@^1",
		"es-iterator-helpers": "npm:@socketregistry/es-iterator-helpers@^1",
