{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "shopflare",
	"compatibility_date": "2026-01-16",
	"main": "./app/entry.worker.ts",
	"dev": {
		"port": 8080
	},
	"kv_namespaces": [
		{
			"binding": "SESSION_KV",
			"id": "?"
		}
	],
	"logpush": true,
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1
	},
	"placement": {
		"mode": "smart"
	},
	"queues": {
		"consumers": [
			{
				"queue": "shopflare"
			}
		],
		"producers": [
			{
				"queue": "shopflare",
				"binding": "WEBHOOK_QUEUE"
			}
		]
	},
	"routes": [
		{
			"custom_domain": true,
			"pattern": "?"
		}
	],
	"secrets": {
		"required": ["SHOPIFY_API_SECRET"]
	},
	"send_metrics": false,
	"upload_source_maps": true,
	"vars": {
		"NODE_VERSION": 22,
		"SHOPIFY_API_KEY": "",
		"SHOPIFY_APP_HANDLE": "",
		"SHOPIFY_APP_URL": ""
	},
	"workers_dev": false
}
